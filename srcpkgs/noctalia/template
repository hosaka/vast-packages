# curl -sL https://api.github.com/repos/noctalia-dev/noctalia/commits/main | jq -r '.sha' | cut -c 1-7
CXXFLAGS="-std=c++23"

do_fetch() {
	git clone https://github.com/noctalia-dev/noctalia.git ${wrksrc}
	cd ${wrksrc}
	git checkout ${version##*.}
}

post_install() {
	vlicense LICENSE
}
