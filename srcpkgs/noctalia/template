version=5.0.0.a5eeef1
revision=1
build_style=meson
# configure_args="--buildtype=release"
hostmakedepends="pkg-config git"
makedepends="MesaLib-devel basu-devel cairo-devel fontconfig-devel freetype-devel
 harfbuzz-devel jemalloc-devel libcurl-devel libepoxy-devel libglvnd-devel
 libqalculate-devel librsvg-devel libwebp-devel libxkbcommon-devel libxml2-devel
 pam-devel pango-devel pipewire-devel polkit-devel sdbus-c++-devel wayland-devel
 wayland-protocols"
depends="wayland pipewire pam libwebp basu jemalloc"
