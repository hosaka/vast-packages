# Template file for 'gram'
pkgname=gram
version=3.0.1
revision=1
build_style=cargo
make_build_args="--package cli --package gram"
hostmakedepends="pkg-config gettext protobuf mold clang cmake"
makedepends="alsa-lib-devel fontconfig-devel libxcb-devel libxkbcommon-devel
 libzstd-devel wayland-devel vulkan-loader openssl-devel sqlite-devel
 libgit2-1.9-devel libX11-devel"
depends="git"
short_desc="Gram Code Editor"
maintainer="Alex March <alex@hosaka.cc>"
license="GPL-3.0-or-later OR Apache-2.0 OR AGPL-3.0-or-later"
homepage="https://gram.liten.app/"
distfiles="https://codeberg.org/GramEditor/gram/archive/${version}.tar.gz"
checksum=4fc7521b417e56a990920f985656be0f72f16a957405d299cfbe6ea9c5e7fa94

export LIBGIT2_NO_VENDOR=1
export LIBSQLITE3_SYS_USE_PKG_CONFIG=1
export LIBSSH2_SYS_USE_PKG_CONFIG=1
export OPENSSL_NO_VENDOR=true
export RUST_FONTCONFIG_DLOPEN=1
export ZSTD_SYS_USE_PKG_CONFIG=1
export GRAM_NO_BUNDLED_UNINSTALL='Use xbps to uninstall'
export RELEASE_VERSION="${version}"

do_install() {
	vbin target/${RUST_TARGET}/release/cli gram
	vinstall target/${RUST_TARGET}/release/gram 755 usr/libexec/ gram-editor
}

post_install() {
	APP_ARGS="%U" APP_CLI="gram" APP_ICON="gram" APP_NAME="Gram" DO_STARTUP_NOTIFY="true" \
		envsubst < crates/gram/resources/gram.desktop.in > crates/gram/resources/gram.desktop

	vinstall crates/gram/resources/gram.desktop 644 usr/share/applications/
	vinstall crates/gram/resources/app-icon.png 644 usr/share/icons/hicolor/512x512/apps/ gram.png
	vinstall crates/gram/resources/app-icon@2x.png 644 usr/share/icons/hicolor/1024x1024/apps/ gram.png

	vlicense LICENSE-APACHE
	vlicense LICENSE-GPL
}
