monaspace-fonts-nerdfonts_package() {
	short_desc+=" - fonts patched with NerdFonts glyphs"
	font_dirs="/usr/share/fonts/monaspace/NerdFonts"
	depends="font-util"
	pkg_install() {
		vmove usr/share/fonts/monaspace/NerdFonts
	}
}
