# Template file for 'opencode'
pkgname=opencode
version=1.17.18
revision=1
hostmakedepends="nodejs python3"
short_desc="Open source coding agent"
maintainer="Alex March <alex@hosaka.cc>"
license="MIT"
homepage="https://opencode.ai"
distfiles="https://github.com/anomalyco/opencode/archive/refs/tags/v${version}.tar.gz"
checksum=37e4a0a6560eb6f7fa57a09efe408dbf2784b773c04b10618df9b1e4453abbe0
nostrip=yes

build_options="nowebui"
build_options_default="nowebui"
desc_option_nowebui="Build without embedded Web UI"

export OPENCODE_VERSION=${version}

do_build() {
	npm install -g bun
	bun install --frozen-lockfile --cpu=x64 --os=linux
	packages/opencode/script/build.ts --single $(vopt_if nowebui --skip-embed-web-ui)
}

# do_check() {
# 	bun test --cwd packages/opencode
# }

do_install() {
	vlicense LICENSE
	vbin packages/opencode/dist/opencode-linux-x64/bin/opencode
}
