# Template file for 'noctalia-qs'
pkgname=noctalia-qs
version=0.0.6
revision=1
build_style=cmake
configure_args="-DDISTRIBUTOR=Void -DDISTRIBUTOR_DEBUGINFO_AVAILABLE=YES
 -DINSTALL_QML_PREFIX=lib/qt6/qml -DCRASH_REPORTER=OFF -DCMAKE_BUILD_TYPE=Release"
hostmakedepends="git pkg-config wayland-devel qt6-base qt6-declarative-devel
 qt6-shadertools"
makedepends="cli11 qt6-base-private-devel qt6-declarative-private-devel
 qt6-shadertools-devel pipewire-devel jemalloc-devel pam-devel polkit-devel"
depends="qt6-svg"
short_desc="Custom fork of Quickshell powering Noctalia Shell"
maintainer="Alex March <alex@hosaka.cc>"
license="LGPL-3.0-only"
homepage="https://github.com/noctalia-dev/noctalia-qs"
distfiles="https://github.com/noctalia-dev/noctalia-qs/archive/v${version}.tar.gz"
checksum=d8cc89ed32a723f845e2cd5d452949ccd21f2d9bd047712ed296ed5dd267d3bd
conflicts="quickshell"

pre_configure() {
	local GIT_REVISION="$(curl -s "https://api.github.com/repos/noctalia-dev/noctalia-qs/git/refs/tags/v${version}" | grep '"sha"' | head -1 | cut -d'"' -f4)"
	configure_args+=" -DGIT_REVISION=$GIT_REVISION"
}
