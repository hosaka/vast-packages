pre_configure() {
	local rev
  rev=$(curl -s https://api.github.com/repos/noctalia-dev/noctalia-qs/git/refs/tags/v${version} | jq '.["object"].["sha"]' )
	configure_args+=" -DGIT_REVISION=${rev}"
}
